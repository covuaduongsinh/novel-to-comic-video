# Cấu hình ứng dụng
DEBUG=True
SECRET_KEY=your-secret-key-here
HOST=0.0.0.0
PORT=5000
FLASK_ENV=dev

# Thông tin xác thực Vbee TTS (bắt buộc, dùng cho tổng hợp giọng nói)
VBEE_APP_ID=your-vbee-app-id
VBEE_ACCESS_TOKEN=your-vbee-access-token

# Hugging Face token (tuỳ chọn, dùng để tải các mô hình bị giới hạn)
HF_API_KEY=

# Tham số tạo hình ảnh (giữ kích thước nhỏ khi không có GPU)
IMAGE_WIDTH=512
IMAGE_HEIGHT=384
DEFAULT_MODEL=stable-diffusion-v1-5/stable-diffusion-v1-5

# Tinh chỉnh hiệu năng CPU
NUM_INFERENCE_STEPS=20
MAX_SCENES=5

# Tham số tạo video
FPS=24
VIDEO_CODEC=libx264
AUDIO_CODEC=aac

# Giọng nói mặc định (mã giọng Vbee)
DEFAULT_VOICE=hn_female_ngochuyen_full_48k-fhg

# Giới hạn hệ thống
MAX_TEXT_LENGTH=5000
CACHE_TIMEOUT=3600
TASK_TIMEOUT=600
