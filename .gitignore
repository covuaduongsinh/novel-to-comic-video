# Môi trường ảo Python
venv/
env/
.env

# Tệp bộ nhớ đệm Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Tệp log
*.log
logs/

# Tệp và thư mục tạm
tmp/
temp/

# Tệp tải lên và đầu ra
uploads/
outputs/

# Tệp hệ thống
.DS_Store
Thumbs.db

# Tệp cấu hình IDE
.idea/
.vscode/
*.swp
*.swo

# Bộ nhớ đệm phụ thuộc
.pip_cache/

# Tệp phân phối
dist/
build/
*.egg-info/

# Báo cáo độ phủ kiểm thử
.coverage
htmlcov/

# Tệp cấu hình cục bộ
config.local.py

# Tệp nhạc nền (người dùng cần tự tải xuống)
static/audio/*.mp3
static/audio/*.wav
!static/audio/README.txt
